{
  "expo": {
    "name": "PokeType",
    "slug": "RNPokeType",
    "version": "1.1.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "checkAutomatically": "ON_LOAD"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "buildNumber": "1.0.2",
      "supportsTablet": true,
      "bundleIdentifier": "com.pgkrsk.pokemontypecalculator"
    },
    "android": {
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.pgkrsk.pokemontypecalculator",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "0260b078-b156-497c-b346-8712aa1ec946"
      }
    },
    "plugins": [
      "expo-image",
      ["react-native-android-widget", {
        "widgets": [{
          "name": "TypeEffectiveness",
          "label": "Type Matchup",
          "description": "See type effectiveness for a dual-type defender",
          "minWidth": "250dp",
          "minHeight": "180dp",
          "targetCellWidth": 4,
          "targetCellHeight": 2,
          "previewImage": "./assets/widget-preview.png",
          "resizeMode": "horizontal|vertical",
          "widgetFeatures": "reconfigurable|configuration_optional",
          "initialLayout": "TypeEffectivenessWidget"
        }]
      }]
    ]
  }
}
